  "content": {
    "user_title": "Create JSON Canvas Visual Notes",
    "value_statement": "Users struggle to create visual canvases in Obsidian without a proper JSON format guide. This skill provides complete reference documentation for creating and editing JSON Canvas files with nodes, edges, groups, and connections.",
    "seo_keywords": [
      "json canvas",
      "obsidian canvas",
      "claude code",
      "codex",
      "visual notes",
      "mind map",
      "json canvas skill",
      "canvas file format",
      "obsidian skill",
      "claude"
    ],
    "actual_capabilities": [
      "Create new .canvas files with proper JSON structure",
      "Add text, file, link, and group nodes with correct attributes",
      "Connect nodes using edges with fromNode/toNode references",
      "Generate unique 16-character hex IDs for nodes and edges",
      "Validate canvas JSON for duplicate IDs and dangling references",
      "Format node positions and dimensions for clean layouts"
    ],
    "limitations": [
      "Does not render canvases visually - only handles JSON file creation and editing",
      "Does not provide Obsidian-specific features beyond the JSON Canvas spec",
      "Does not import from or export to other visual formats",
      "Requires manual coordinate positioning for layout"
    ],
    "use_cases": [
      {
        "title": "Create Mind Maps",
        "description": "Generate structured mind maps with central topics and connected branches using text nodes and edges.",
        "target_user": "Note-takers and knowledge workers"
      },
      {
        "title": "Build Project Boards",
        "description": "Organize tasks into kanban-style boards using group nodes for columns and text nodes for cards.",
        "target_user": "Project managers and developers"
      },
      {
        "title": "Design Research Canvases",
        "description": "Create visual research overviews combining text notes, file references, and external links.",
        "target_user": "Researchers and students"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create Simple Canvas",
        "prompt": "Create a new .canvas file called 'meeting-notes.canvas' with a main text node containing meeting notes and two connected nodes for action items.",
        "scenario": "Beginner - basic canvas creation"
      },
      {
        "title": "Add Nodes to Canvas",
        "prompt": "Add three new text nodes to 'project.canvas' positioned to the right of the existing nodes. Connect each new node to the main node with labeled edges.",
        "scenario": "Intermediate - adding content"
      },
      {
        "title": "Build Kanban Board",
        "prompt": "Create a project board canvas with three group nodes for 'To Do', 'In Progress', and 'Done' columns. Add five task nodes distributed across the columns.",
        "scenario": "Intermediate - structured layouts"
      },
      {
        "title": "Research Canvas",
        "prompt": "Create a research canvas with a central topic node, three file reference nodes pointing to PDF documents, and two external link nodes. Connect all nodes to the central topic.",
        "scenario": "Advanced - complex structures"
      }
    ],
    "output_examples": [
      {
        "input": "Create a simple canvas with one text node",
        "output": "A .canvas file is created with a nodes array containing a text node with id, type, x, y, width, height, and text fields. An empty edges array is also included."
      },
      {
        "input": "Add a connection between two nodes",
        "output": "The edge array gains a new object with fromNode and toNode referencing the existing node IDs. The connection appears as a line linking the two nodes in Obsidian."
      },
      {
        "input": "Create a three-column kanban board",
        "output": "A canvas with three group nodes labeled 'To Do', 'In Progress', 'Done' with color coding. Task text nodes are positioned inside each group column."
      }
    ],
    "best_practices": [
      "Always validate JSON after creating or editing canvas files to catch duplicate IDs and broken edge references",
      "Use consistent spacing (50-100px) between nodes and align to grid multiples for cleaner layouts",
      "Test canvas files in Obsidian to verify visual rendering matches intended layout"
    ],
    "anti_patterns": [
      "Using unescaped newline characters in text content (use \\n instead of literal newlines)",
      "Creating duplicate node IDs which causes canvas rendering errors",
      "Referencing node IDs in edges that do not exist in the nodes array"
    ],
    "faq": [
      {
        "question": "What is a JSON Canvas file?",
        "answer": "JSON Canvas is a file format used by Obsidian for visual canvases. It stores nodes (text, files, links, groups) and edges (connections) in a JSON structure."
      },
      {
        "question": "How do I create a new canvas file?",
        "answer": "Create a new .canvas file with the basic structure: {\"nodes\": [], \"edges\": []}. Add nodes with required fields: id, type, x, y, width, height."
      },
      {
        "question": "What node types are supported?",
        "answer": "Four node types: text (Markdown content), file (file references), link (external URLs), and group (visual containers)."
      },
      {
        "question": "How do I connect two nodes?",
        "answer": "Add an edge object with a unique id, fromNode (source node ID), and toNode (target node ID). Optionally add fromSide/toSide for anchor points."
      },
      {
        "question": "Why is my canvas not loading in Obsidian?",
        "answer": "Common issues: duplicate node IDs, broken edge references (fromNode/toNode pointing to non-existent nodes), or invalid JSON syntax. Validate the JSON first."
      },
      {
        "question": "Can I use colors in canvas nodes?",
        "answer": "Yes, use the color attribute with preset values \"1\"-\"6\" (red, orange, yellow, green, cyan, purple) or hex color codes like \"#FF0000\"."
      }
    ]
  },
