    "user_title": "Organize Obsidian Notes with PARA Method",
    "value_statement": "Claude users struggle to organize their Obsidian notes consistently. This skill provides automated PARA classification, routing, and vault hygiene reviews to keep knowledge bases organized without manual effort.",
    "seo_keywords": [
      "PARA method",
      "Obsidian vault organization",
      "note classification",
      "knowledge management",
      "Claude",
      "Codex",
      "Claude Code",
      "Obsidian para skill",
      "second brain",
      "Tiago Forte"
    ],
    "actual_capabilities": [
      "Classify any note into PARA categories (Projects, Areas, Resources, Archive) with confidence scoring",
      "Route notes to correct vault folders with optional dry-run mode",
      "Normalize frontmatter with PARA-specific fields without touching existing content",
      "Run vault hygiene reviews to identify stale notes, inbox backlogs, and archiving candidates",
      "Perform full vault audits for missing metadata, wrong placement, and orphaned notes",
      "Suggest defensive archiving with proper metadata preservation"
    ],
    "limitations": [
      "Does not create or modify note body content - only handles classification and frontmatter",
      "Requires existing Obsidian vault structure - cannot initialize a new vault from scratch",
      "Depends on note content quality for accurate classification - ambiguous notes need manual review",
      "Cannot access or manage Dataview queries, plugins, or Obsidian-specific configurations"
    ],
    "use_cases": [
      {
        "title": "Organize Meeting Notes Automatically",
        "description": "Capture new meeting notes and have Claude classify them into the correct PARA category, add appropriate frontmatter, and route to the right folder in the vault.",
        "target_user": "Knowledge workers who take frequent meeting notes in Obsidian"
      },
      {
        "title": "Quarterly Vault Cleanup",
        "description": "Run a comprehensive hygiene review to identify stale projects, outdated areas, and archiving candidates. Get a prioritized action list for vault maintenance.",
        "target_user": "Obsidian power users with large vaults"
      },
      {
        "title": "Note Classification Assistant",
        "description": "Ask Claude where a specific note belongs in the PARA structure. Get classification reasoning with confidence level before any changes are made.",
        "target_user": "PARA method practitioners who want decision support"
      }
    ],
    "prompt_templates": [
      {
        "title": "Classify a Note",
        "prompt": "Classify this note into the correct PARA category. Read the note content and determine if it belongs in Projects, Areas, Resources, or Archive. Explain your reasoning with at least 2 supporting signals.\n\nNote content:\n{NOTE_CONTENT}",
        "scenario": "When user wants to understand where a specific note belongs"
      },
      {
        "title": "Run Vault Review",
        "prompt": "Run a PARA hygiene review on my Obsidian vault. Check for: projects without next steps, stale areas, inbox backlog, and archiving candidates. Provide a prioritized action list.",
        "scenario": "When user wants periodic vault maintenance"
      },
      {
        "title": "Capture New Note",
        "prompt": "Process this new content using the PARA method. Classify it, suggest the correct folder path, and create appropriate frontmatter.\n\nContent to capture:\n{CONTENT}",
        "scenario": "When user adds new information to their knowledge system"
      },
      {
        "title": "Normalize Frontmatter",
        "prompt": "Normalize the frontmatter of this note. Add missing PARA-specific fields (para_type, status, confidence, needs_review) without removing or modifying existing non-PARA fields.\n\nNote path: {NOTE_PATH}",
        "scenario": "When user wants to add consistent metadata to existing notes"
      }
    ],
    "output_examples": [
      {
        "input": "Classify this note: 'Workshop Planning - Führungsteam April' - includes meeting notes, action items with deadlines, and next steps",
        "output": "Classification: Project (confidence: high)\n\nReasoning:\n- Contains concrete initiative with defined endpoint (April workshop)\n- Has deadlines and action items (strong project indicators)\n- No ongoing responsibilities or recurring nature\n\nSuggested path: 1_Projects/leadership-workshop/\n\nFrontmatter to add:\n- para_type: project\n- status: active\n- confidence: high\n- needs_review: false"
      },
      {
        "input": "Run a PARA hygiene review on my vault",
        "output": "## Vault Hygiene Report\n\n### Projects needing attention (3)\n- Project X: No next steps in 30+ days\n- Project Y: Status unclear, needs review\n\n### Inbox backlog (12 notes)\n- 0_Inbox/ contains unprocessed notes\n\n### Archiving candidates (5)\n- Notes in Projects marked 'done' for 90+ days\n\n### Action items:\n1. Review 3 stale projects\n2. Process 12 inbox notes\n3. Archive 5 completed projects"
      }
    ],
    "best_practices": [
      "Use cautious mode (default) for the first few interactions to understand the classification logic before enabling automatic moves",
      "Review the classification reasoning to learn what signals the skill uses - this improves your note-writing for future classifications",
      "Run quarterly hygiene reviews to prevent vault drift and maintain long-term organization"
    ],
    "anti_patterns": [
      "Using aggressive mode without understanding the classification criteria first - may misclassify ambiguous notes",
      "Ignoring the confidence score and forcing classifications when confidence is low",
      "Running full vault audits on very large vaults without breaking into smaller sections first"
    ],
    "faq": [
      {
        "question": "What is the PARA method?",
        "answer": "PARA is an organizational framework by Tiago Forte that structures information by action relevance. It divides information into four categories: Projects (concrete initiatives with goals), Areas (ongoing responsibilities), Resources (reference knowledge), and Archive (inactive content)."
      },
      {
        "question": "Does this skill create files in my vault?",
        "answer": "In cautious mode (default), it only suggests classifications and changes without making them. In balanced or aggressive mode with explicit permission, it can create or modify files. Always review before confirming changes."
      },
      {
        "question": "Can I use this with other Obsidian skills?",
        "answer": "Yes, this skill is designed to work alongside obsidian-markdown and obsidian-cli. It handles classification logic while delegating file operations to other skills."
      },
      {
        "question": "How accurate is the classification?",
        "answer": "Accuracy depends on note content quality. The skill provides confidence scores (high, medium, low). Notes with clear project indicators, area responsibilities, or resource characteristics score higher."
      },
      {
        "question": "What does the confidence score mean?",
        "answer": "High confidence means 2+ strong indicators for a PARA category. Medium means ambiguous signals. Low means insufficient information - the skill will suggest needs_review: true."
      },
      {
        "question": "Is this skill affiliated with Tiago Forte?",
        "answer": "No, this is an independent unofficial implementation of the PARA framework. The PARA method was created by Tiago Forte and described in his book Building a Second Brain."
      }
    ]
